# 推理服务地址（本地 RAFT 模型服务，见 finetuning/qwen3/serve/server.py）
LLM_BASE_URL=http://localhost:8001
LLM_MODEL=qwen3-raft

# （可选）外部 HTTPS API 备用，不使用本地模型时填写
# LLM_BASE_URL=https://api.example.com
# LLM_KEY=sk-...

# Milvus 向量数据库连接
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=insurance_kb
MILVUS_DIM=768
EMBEDDING_MODEL_NAME=all-mpnet-base-v2
